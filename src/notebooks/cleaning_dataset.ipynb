   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_deep_learning_data(df):\n",
    "    # 1. Sort by participant and time to keep sequences intact\n",
    "    df = df.sort_values(['Participant name', 'Recording timestamp'])\n",
    "\n",
    "    # 2. Separate Numeric and Categorical columns automatically\n",
    "    # This prevents the TypeError by only interpolating numbers\n",
    "    numeric_features = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "    categorical_features = df.select_dtypes(exclude=[np.number]).columns.tolist()\n",
    "    \n",
    "    # 3. Numeric Cleaning: Interpolation\n",
    "    # We only apply this to the numeric_features list\n",
    "    if numeric_features:\n",
    "        df[numeric_features] = df.groupby('Participant name')[numeric_features].transform(\n",
    "            lambda x: x.interpolate(method='linear', limit_direction='both')\n",
    "        )\n",
    "        \n",
    "        # 4. Fill remaining numeric NaNs (at start/end) with Forward/Backward fill\n",
    "        df[numeric_features] = df.groupby('Participant name')[numeric_features].transform(\n",
    "            lambda x: x.ffill().bfill()\n",
    "        )\n",
    "\n",
    "    # 5. Categorical Cleaning: Forward/Backward fill\n",
    "    # For columns like 'Eye movement type', we can't interpolate, so we fill gaps\n",
    "    if categorical_features:\n",
    "        # Avoid filling 'Participant name' as it's our grouping key\n",
    "        cat_to_fill = [c for c in categorical_features if c not in ['Participant name']]\n",
    "        df[cat_to_fill] = df.groupby('Participant name')[cat_to_fill].transform(\n",
    "            lambda x: x.ffill().bfill()\n",
    "        )\n",
    "    \n",
    "    return df\n",
    "\n"
   ]
  },
